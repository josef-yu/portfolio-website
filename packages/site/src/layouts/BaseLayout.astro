---
import CmdK from '@site/components/CmdK.astro';
import Footer from '@site/components/Footer.astro';
import MainHead from '@site/components/MainHead.astro';
import Nav from '@site/components/Nav.astro';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;
---

<html lang="en">
	<head>
		<MainHead title={title} description={description} />
	</head>
	<body>
		<Nav />
		<slot />
		<Footer />
		<CmdK />
	</body>
</html>
