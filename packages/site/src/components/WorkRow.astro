---
interface Props {
	id: string;
	role: string;
	employer: string;
	org?: string;
	location: string;
	startDate: Date;
	endDate?: Date;
	summary?: string;
	techStack: Array<{ name: string }>;
	/** compact=true → inline date + arrow, no tech stack (home page style) */
	compact?: boolean;
}

const {
	id,
	role,
	employer,
	org,
	location,
	startDate,
	endDate,
	summary,
	techStack,
	compact = false,
} = Astro.props;

const fmtDate = (d: Date) =>
	d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

{compact ? (
	<a class="xp-row" href={`/work/${id}`}>
		<div class="xp-when">
			{fmtDate(startDate)} <span class="dash">→</span> {endDate ? fmtDate(endDate) : 'Present'}
		</div>
		<div class="xp-main">
			<h3>{role}</h3>
			<div class="co">
				{employer}{org && <><span class="sep">·</span> {org}</>}
				<span class="sep">·</span> {location}
			</div>
			{summary && <p>{summary}</p>}
		</div>
		<div class="xp-arrow">↗</div>
	</a>
) : (
	<a href={`/work/${id}`} class="xp-full-row">
		<div class="when">
			{fmtDate(startDate)}<br />
			<span class="arrow-down">↓</span><br />
			{endDate ? fmtDate(endDate) : 'Present'}
		</div>
		<div class="xp-body">
			<div class="row-head">
				<h3>{role}</h3>
				<span class="read-detail">Read detail →</span>
			</div>
			<div class="co">
				{employer}{org && <><span class="sep">·</span> {org}</>}
				<span class="sep">·</span> {location}
			</div>
			{summary && <p class="summary">{summary}</p>}
			<div class="xp-stack">
				{techStack.map((t) => (
					<span class="tag">{t.name}</span>
				))}
			</div>
		</div>
	</a>
)}

<style>
	/* ── Shared ─────────────────────────────────────────────────────────── */
	.co {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
	}

	.co .sep { margin: 0 6px; opacity: 0.5; }

	/* ── Compact (home page) ────────────────────────────────────────────── */
	.xp-row {
		display: grid;
		grid-template-columns: 160px 1fr auto;
		gap: 32px;
		padding: 20px 0;
		border-bottom: 1px solid var(--line);
		align-items: baseline;
		text-decoration: none;
		color: inherit;
		transition: padding-left 0.2s ease;
	}

	.xp-row:hover { padding-left: 8px; }

	.xp-when {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
		padding-top: 3px;
		white-space: nowrap;
	}

	.xp-when .dash { margin: 0 4px; opacity: 0.5; }

	.xp-main h3 {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 17px;
		letter-spacing: -0.005em;
		margin: 0 0 4px;
		color: var(--ink);
	}

	.xp-row .co { margin-bottom: 8px; }

	.xp-main p {
		color: var(--ink-2);
		font-size: 14.5px;
		line-height: 1.55;
		max-width: 560px;
		margin: 0;
	}

	.xp-arrow {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--ink-3);
		padding-top: 3px;
		transition: color 0.18s;
	}

	.xp-row:hover .xp-arrow { color: var(--ink); }

	/* ── Full (work page) ───────────────────────────────────────────────── */
	.xp-full-row {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 40px;
		padding: 32px 0;
		border-top: 1px solid var(--line);
		text-decoration: none;
		color: inherit;
		transition: background-color 0.2s ease;
	}

	.xp-full-row:last-child { border-bottom: 1px solid var(--line); }

	.xp-full-row:hover .read-detail { color: var(--ink); }

	.when {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
		line-height: 1.8;
	}

	.when .arrow-down { opacity: 0.6; }

	.row-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 16px;
	}

	.xp-body h3 {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 22px;
		margin: 0 0 4px;
		letter-spacing: -0.012em;
		color: var(--ink);
	}

	.read-detail {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
		white-space: nowrap;
		flex-shrink: 0;
		transition: color 0.18s;
	}

	.xp-full-row .co { margin-bottom: 16px; }

	.summary {
		color: var(--ink-2);
		font-size: 15px;
		line-height: 1.6;
		max-width: 620px;
		margin-bottom: 0;
		text-wrap: pretty;
	}

	.xp-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 14px;
	}

	.tag {
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: 0.02em;
		padding: 2px 8px;
		border-radius: 999px;
		color: var(--ink-2);
		border: 1px solid var(--line);
		background: var(--surface);
		white-space: nowrap;
	}

	/* ── Responsive ─────────────────────────────────────────────────────── */
	@media (max-width: 820px) {
		/* Compact */
		.xp-row {
			grid-template-columns: 1fr;
			gap: 6px;
			padding: 16px 0;
		}
		.xp-arrow { display: none; }

		/* Full */
		.xp-full-row {
			grid-template-columns: 1fr;
			gap: 12px;
			padding: 24px 0;
		}
		.when {
			display: flex;
			gap: 6px;
			align-items: center;
			font-size: 11px;
		}
		.when br { display: none; }
		.when .arrow-down { font-size: 0; line-height: 0; }
		.when .arrow-down::after {
			content: "→";
			font-family: var(--font-mono);
			font-size: 11px;
			line-height: 1;
			opacity: 0.6;
			color: var(--ink-3);
		}
		.xp-body h3 { font-size: 19px; }
		.xp-full-row .co { font-size: 11px; margin-bottom: 12px; }
		.summary { font-size: 14.5px; }
	}

	@media (max-width: 560px) {
		.xp-full-row { padding: 20px 0; }
		.xp-body h3 { font-size: 18px; }
	}
</style>
