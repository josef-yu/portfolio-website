---
interface Props {
	id: string;
	title: string;
	description: string;
	publishDate: Date;
	tags: string[];
	readMin?: number;
}

const { id, title, description, publishDate, tags, readMin } = Astro.props;

const fmtDate = (d: Date) =>
	d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<a class="post-row" href={`/writing/${id}`} data-tags={tags.join(',')}>
	<div class="date">{fmtDate(publishDate)}</div>
	<div>
		<h3 class="post-title">{title}</h3>
		<div class="ex">{description}</div>
	</div>
	<div class="meta">
		{tags[0] && <span>{tags[0]}</span>}
		{readMin && <span>{readMin} min</span>}
	</div>
	<div class="arrow">→</div>
</a>

<style>
	.post-row {
		display: grid;
		grid-template-columns: 110px 1fr 160px 32px;
		gap: 24px;
		padding: 18px 0;
		border-bottom: 1px solid var(--line);
		align-items: baseline;
		text-decoration: none;
		color: inherit;
		transition: background-color 0.18s, padding 0.18s;
	}

	.post-row:hover { padding-left: 10px; padding-right: 10px; }

	.post-row .date {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
	}

	.post-row h3.post-title {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 16.5px;
		letter-spacing: -0.012em;
		margin: 0 0 4px;
		line-height: 1.3;
		color: var(--ink);
	}

	.post-row .ex {
		font-size: 13.5px;
		color: var(--ink-2);
		line-height: 1.5;
		max-width: 540px;
		text-wrap: pretty;
	}

	.post-row .meta {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink-3);
		letter-spacing: 0.04em;
		display: flex;
		flex-direction: column;
		gap: 4px;
		text-transform: uppercase;
	}

	.post-row .arrow {
		font-family: var(--font-mono);
		font-size: 14px;
		color: var(--ink-3);
		transition: transform 0.2s, color 0.2s;
	}

	.post-row:hover .arrow { color: var(--ink); transform: translateX(3px); }

	/* ── Responsive ─────────────────────────────────────────────────────── */
	@media (max-width: 820px) {
		.post-row { grid-template-columns: 90px 1fr; gap: 14px; padding: 16px 0; }
		.post-row:hover { padding-left: 6px; padding-right: 6px; }
		.post-row .meta, .post-row .arrow { display: none; }
	}

	@media (max-width: 560px) {
		.post-row { grid-template-columns: 1fr; gap: 4px; padding: 14px 0; }
		.post-row:hover { padding-left: 0; padding-right: 0; }
		.post-row .date { font-size: 11px; }
		.post-row h3.post-title { font-size: 16px; }
		.post-row .ex { font-size: 13px; }
	}
</style>
