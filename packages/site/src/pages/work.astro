---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allWork = (await getCollection('work')).sort(
	(a, b) =>
		(b.data.endDate?.valueOf() ?? Date.now()) -
		(a.data.endDate?.valueOf() ?? Date.now()),
);

const fmtDate = (d: Date) =>
	d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<BaseLayout
	title="Work — Joseph Yu"
	description="Six roles, four companies, one through-line: backend systems that other people end up depending on."
>
	<main>
		<header class="wrap page-head">
			<div class="crumbs">
				<a href="/">Home</a>
				<span class="sep">/</span>
				<span>Work</span>
			</div>
			<h1>Where I've been useful.</h1>
			<p class="sub">Six roles, four companies, one through-line: backend systems that other people end up depending on. Currently leading the team at Cambria.</p>
		</header>

		<div class="wrap main-content">
			<div class="xp-list">
				{allWork.map((w) => (
					<a href={`/work/${w.id}`} class="xp-full-row">
						<div class="when">
							{fmtDate(w.data.startDate)}<br />
							<span class="arrow-down">↓</span><br />
							{w.data.endDate ? fmtDate(w.data.endDate) : 'Present'}
						</div>
						<div class="xp-body">
							<div class="row-head">
								<h3>{w.data.role}</h3>
								<span class="read-detail">Read detail →</span>
							</div>
							<div class="co">
								{w.data.employer}{w.data.org && <><span class="sep">·</span> {w.data.org}</>}
								<span class="sep">·</span> {w.data.location}
							</div>
							{w.data.summary && <p class="summary">{w.data.summary}</p>}
							<div class="xp-stack">
								{w.data.tech_stack.map((t) => (
									<span class="tag">{t.name}</span>
								))}
							</div>
						</div>
					</a>
				))}
			</div>

			<div class="edu-bar">
				<span>
					Education · <strong>Ateneo de Davao University</strong> · Bachelor of Science in Computer Science
				</span>
				<a href="/about/" class="more">About me →</a>
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	/* ── Page header (base styles from global.css) ─────────────────────── */

	/* ── Main content ───────────────────────────────────────────────────── */
	.main-content {
		padding-block: 48px 96px;
	}

	/* ── Experience rows ────────────────────────────────────────────────── */
	.xp-full-row {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 40px;
		padding: 32px 0;
		border-top: 1px solid var(--line);
		text-decoration: none;
		color: inherit;
		transition: background-color 0.2s ease;
	}

	.xp-full-row:last-child { border-bottom: 1px solid var(--line); }

	.xp-full-row:hover .read-detail { color: var(--ink); }

	.when {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
		line-height: 1.8;
	}

	.when .arrow-down { opacity: 0.6; }

	.row-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 16px;
	}

	.xp-body h3 {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 22px;
		margin: 0 0 4px;
		letter-spacing: -0.012em;
		color: var(--ink);
	}

	.read-detail {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
		white-space: nowrap;
		flex-shrink: 0;
		transition: color 0.18s;
	}

	.co {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
		margin-bottom: 16px;
	}

	.co .sep { margin: 0 6px; opacity: 0.5; }

	.summary {
		color: var(--ink-2);
		font-size: 15px;
		line-height: 1.6;
		max-width: 620px;
		margin-bottom: 0;
		text-wrap: pretty;
	}

	/* ── Tech tags ──────────────────────────────────────────────────────── */
	.xp-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 14px;
	}

	.tag {
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: 0.02em;
		padding: 2px 8px;
		border-radius: 999px;
		color: var(--ink-2);
		border: 1px solid var(--line);
		background: var(--surface);
		white-space: nowrap;
	}

	/* ── Education bar ──────────────────────────────────────────────────── */
	.edu-bar {
		margin-top: 56px;
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
		gap: 16px;
		flex-wrap: wrap;
	}

	.edu-bar strong {
		color: var(--ink-2);
		font-weight: 500;
	}

	.edu-bar .more {
		color: var(--ink-2);
		text-decoration: none;
		transition: color 0.18s;
		white-space: nowrap;
	}

	.edu-bar .more:hover { color: var(--ink); }

	/* ── Responsive ─────────────────────────────────────────────────────── */
	@media (max-width: 820px) {
		.xp-full-row {
			grid-template-columns: 1fr;
			gap: 12px;
			padding: 24px 0;
		}

		.when {
			display: flex;
			gap: 6px;
			align-items: center;
			font-size: 11px;
		}

		.when br { display: none; }

		.when .arrow-down { font-size: 0; line-height: 0; }
		.when .arrow-down::after {
			content: "→";
			font-family: var(--font-mono);
			font-size: 11px;
			line-height: 1;
			opacity: 0.6;
			color: var(--ink-3);
		}

		.xp-body h3 { font-size: 19px; }

		.co { font-size: 11px; margin-bottom: 12px; }

		.summary { font-size: 14.5px; }
	}

	@media (max-width: 560px) {
		.page-head h1 { font-size: clamp(26px, 7vw, 34px); }
		.page-head .sub { font-size: 14.5px; }
		.page-head .crumbs { font-size: 11px; }
		.main-content { padding-block: 32px 64px; }
		.xp-full-row { padding: 20px 0; }
		.xp-body h3 { font-size: 18px; }
	}
</style>
