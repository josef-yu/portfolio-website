---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allWork = await getCollection('work');
const allProjects = await getCollection('project');

const projects = allProjects
	.map((project) => {
		const relatedWork = allWork.filter((w) =>
			w.data.projects.some((ref) => ref.id === project.id),
		);

		const sortedByRecent = [...relatedWork].sort(
			(a, b) =>
				(b.data.endDate?.valueOf() ?? Date.now()) -
				(a.data.endDate?.valueOf() ?? Date.now()),
		);
		const earliest = [...relatedWork].sort(
			(a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf(),
		)[0];

		const mostRecent = sortedByRecent[0];
		const displayDate = mostRecent
			? (mostRecent.data.endDate ?? new Date())
			: project.data.date!;

		const isActive = relatedWork.some((w) => !w.data.endDate);
		const startYear =
			earliest?.data.startDate.getFullYear() ??
			project.data.date?.getFullYear();
		const endYear = mostRecent?.data.endDate?.getFullYear();

		const yearDisplay = isActive
			? `${startYear}—`
			: endYear
				? String(endYear)
				: String(startYear ?? '');

		const role = mostRecent?.data.role ?? null;

		return { project, displayDate, yearDisplay, role };
	})
	.sort((a, b) => b.displayDate.valueOf() - a.displayDate.valueOf());
---

<BaseLayout
	title="Projects — Joseph Yu"
	description="A non-exhaustive list of projects I've led or contributed to."
>
	<main>
		<header class="wrap page-head">
			<div class="crumbs">
				<a href="/">Home</a>
				<span class="sep">/</span>
				<span>Projects</span>
			</div>
			<h1>Things I've shipped.</h1>
			<p class="sub">A non-exhaustive list of projects I've led or contributed to. Most live behind NDAs, so descriptions are deliberately vague.</p>
		</header>

		<div class="wrap main-content">
			<div class="proj-grid">
				{projects.map(({ project, yearDisplay, role }) => (
					<a class="proj" href={`/projects/${project.id}`}>
						<div class="proj-head">
							<span>{project.data.tags[0]}</span>
							<span>{yearDisplay}</span>
						</div>
						<h3 class="proj-name">{project.data.title}</h3>
						<p class="proj-sum">{project.data.description}</p>
						<div class="proj-foot">
							<div class="proj-stack">
								{project.data.tech_stack.slice(0, 4).map((t) => (
									<span>{t.name}</span>
								))}
							</div>
							{role && <span class="proj-role">{role}</span>}
						</div>
					</a>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	/* ── Page header (base styles from global.css) ─────────────────────── */

	/* ── Main content ───────────────────────────────────────────────────── */
	.main-content {
		padding-block: 48px 96px;
	}

	/* ── Project grid ───────────────────────────────────────────────────── */
	.proj-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		background: var(--line);
		border: 1px solid var(--line);
		border-radius: var(--r-md);
		overflow: hidden;
	}

	.proj {
		background: var(--surface);
		padding: 22px 22px 24px;
		display: flex;
		flex-direction: column;
		gap: 10px;
		min-height: 180px;
		transition: background-color 0.2s ease;
		text-decoration: none;
		color: inherit;
	}

	.proj:hover { background: color-mix(in oklab, var(--surface) 96%, var(--ink-2)); }

	.proj-head {
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 10.5px;
		color: var(--ink-3);
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.proj-name {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 18px;
		letter-spacing: -0.012em;
		margin: 0;
		color: var(--ink);
	}

	.proj-sum {
		color: var(--ink-2);
		font-size: 14px;
		line-height: 1.55;
		flex: 1;
		text-wrap: pretty;
		margin: 0;
	}

	.proj-foot {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
		margin-top: 6px;
		gap: 12px;
	}

	.proj-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 4px 12px;
	}

	.proj-stack span { white-space: nowrap; }

	.proj-role { white-space: nowrap; }

	/* ── Responsive ─────────────────────────────────────────────────────── */
	@media (max-width: 820px) {
		.proj-grid { grid-template-columns: 1fr; }
	}

	@media (max-width: 560px) {
		.page-head h1 { font-size: clamp(26px, 7vw, 34px); }
		.page-head .sub { font-size: 14.5px; }
		.page-head .crumbs { font-size: 11px; }
		.main-content { padding-block: 32px 64px; }
		.proj { padding: 18px 16px 20px; min-height: 0; }
		.proj-name { font-size: 17px; }
	}
</style>
