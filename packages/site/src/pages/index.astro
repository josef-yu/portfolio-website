---
import { getCollection } from 'astro:content';
import BaseLayout from '@site/layouts/BaseLayout.astro';
import WorkList from '@site/components/WorkList.astro';
import ProjectGrid from '@site/components/ProjectGrid.astro';
import PostList from '@site/components/PostList.astro';
import { getTechStack } from '@site/utilities/getTechStack';
import highlights from '@site/data/highlights.json';

const recentPosts = (await getCollection('writing', ({ data }) => !data.draft))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 3);

const allWork = await getCollection('work');

// Timeline: most recent 3 roles flagged for timeline display
const recentWork = allWork
	.filter((w) => w.data.showInTimeline)
	.sort((a, b) =>
		(b.data.endDate?.valueOf() ?? Date.now()) -
		(a.data.endDate?.valueOf() ?? Date.now())
	)
	.slice(0, 3);

// Projects grid: featured projects with dates resolved from linked work entries
const allFeaturedProjects = await getCollection('project', ({ data }) => data.featured);

const projects = allFeaturedProjects
	.map((project) => {
		const relatedWork = allWork.filter((w) =>
			w.data.projects.some((ref) => ref.id === project.id)
		);
		const latestWork = relatedWork.sort(
			(a, b) =>
				(b.data.endDate?.valueOf() ?? Date.now()) -
				(a.data.endDate?.valueOf() ?? Date.now())
		)[0];
		const displayDate = latestWork
			? (latestWork.data.endDate ?? new Date())
			: project.data.date!;
		return { project, displayDate };
	})
	.sort((a, b) => b.displayDate.valueOf() - a.displayDate.valueOf())
	.slice(0, 4);

const homeProjects = projects.map(({ project, displayDate }) => ({
	id: project.id,
	title: project.data.title,
	description: project.data.description,
	tag: project.data.tags[0],
	year: String(displayDate.getFullYear()),
	techStack: project.data.tech_stack,
}));

const techStack = (await getTechStack('work')).slice(0, 5);
const maxElapsed = techStack.reduce((m, t) => Math.max(m, t.elapsed), 0);

---

<BaseLayout title="Joseph Yu — Software Developer" description="Senior backend engineer building tax-compliance software for the Australian property funds sector.">
	<main>
		<!-- Hero -->
		<section class="hero">
			<div class="wrap">
				<div class="hero-pill">
					<span class="pulse" aria-hidden="true"></span>
					<span>Open to senior software engineering roles</span>
				</div>
				<h1>Backend engineer building the <em>boring, important</em> parts of compliance software.</h1>
				<p class="hero-sub">
					Senior backend engineer working on Python, Django, AWS infrastructure, and tax-compliance software for the Australian property funds sector.
				</p>
				<div class="hero-meta">
					<span><strong>Davao, Philippines</strong> · <span id="manila-time">GMT+8</span></span>
					<span><strong>Currently</strong> Team Lead at Cambria</span>
					<span><strong>Stack</strong> Python · Django · AWS</span>
				</div>
				<div class="hero-cta-row">
					<a class="btn" href="mailto:joseph@josefyu.com">Get in touch</a>
					<a class="btn ghost" href="/work/">See experience →</a>
				</div>
				<div class="highlights">
					{highlights.map(({ stat, label }) => (
						<div class="hl">
							<div class="hl-stat">{stat}</div>
							<div class="hl-lbl">{label}</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Tech Stack -->
		<section>
			<div class="wrap">
				<div class="sec-head">
					<h2><span class="n">02</span>Tech stack</h2>
					<a class="more" href="/about/">Full toolbelt →</a>
				</div>
				{techStack.length === 0 ? (
					<p class="empty-notice">No tech stack yet.</p>
				) : (
				<div class="tech-grid">
					{techStack.map((tech, i) => {
						const pct = Math.round((tech.elapsed / maxElapsed) * 100);
						return (
							<div class="tech">
								<span class="rank">{String(i + 1).padStart(2, '0')}</span>
								<h3 class="tech-name">{tech.name}</h3>
								<div class="tech-yrs"><span class="n">{tech.years}</span>{tech.years === 1 ? 'year' : 'years'}</div>
								<div class="tech-bar"><i style={`width: ${pct}%`}></i></div>
								{tech.note && <div class="tech-note">{tech.note.slice(0, 5).join(' · ')}</div>}
							</div>
						);
					})}
				</div>
				)}
			</div>
		</section>

		<!-- Recent Work -->
		<section>
			<div class="wrap">
				<div class="sec-head">
					<h2><span class="n">03</span>Recent work</h2>
					<a class="more" href="/work/">Full timeline →</a>
				</div>
				<WorkList work={recentWork} compact />
			</div>
		</section>

		<!-- Selected Projects -->
		<section>
			<div class="wrap">
				<div class="sec-head">
					<h2><span class="n">04</span>Selected projects</h2>
					<a class="more" href="/projects/">All projects →</a>
				</div>
				<ProjectGrid projects={homeProjects} emptyMessage="No featured projects yet." />
			</div>
		</section>

		<!-- Recent Writing -->
		<section>
			<div class="wrap">
				<div class="sec-head">
					<h2><span class="n">05</span>Recent writing</h2>
					<a class="more" href="/writing/">All posts →</a>
				</div>
				<PostList posts={recentPosts} emptyMessage="No posts yet." />
			</div>
		</section>
	</main>
</BaseLayout>

<script>
	// Live Manila time
	function updateTime() {
		const el = document.getElementById('manila-time');
		if (!el) return;
		el.textContent = new Date().toLocaleTimeString('en-US', {
			hour: 'numeric',
			minute: '2-digit',
			timeZone: 'Asia/Manila',
		}) + ' GMT+8';
	}
	updateTime();
	setInterval(updateTime, 30000);
</script>

<style>
	/* ── Hero ──────────────────────────────────────────────────────────── */
	.hero {
		padding: clamp(72px, 10vw, 128px) 0 clamp(48px, 6vw, 80px);
	}

	.hero-pill {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-2);
		border: 1px solid var(--line);
		background: var(--surface);
		border-radius: 999px;
		padding: 5px 11px 5px 9px;
		margin-bottom: 28px;
	}

	.pulse {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--good);
		box-shadow: 0 0 0 4px var(--good-soft);
		animation: pulse 2.4s ease-in-out infinite;
		flex-shrink: 0;
		display: inline-block;
	}

	@keyframes pulse {
		0%, 100% { box-shadow: 0 0 0 4px var(--good-soft); }
		50% { box-shadow: 0 0 0 8px color-mix(in oklab, var(--good) 4%, transparent); }
	}

	.hero h1 {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: clamp(36px, 5.4vw, 60px);
		letter-spacing: -0.022em;
		line-height: 1.06;
		margin: 0 0 22px;
		max-width: 22ch;
		text-wrap: balance;
		color: var(--ink);
	}

	.hero h1 em {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 400;
		color: var(--accent);
	}

	.hero-sub {
		font-size: 17px;
		max-width: 580px;
		color: var(--ink-2);
		line-height: 1.55;
		text-wrap: pretty;
	}

	.hero-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 6px 24px;
		margin-top: 32px;
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
	}

	.hero-meta strong { color: var(--ink-2); font-weight: 500; }

	.hero-cta-row {
		display: flex;
		gap: 12px;
		margin-top: 28px;
		flex-wrap: wrap;
	}

	/* ── Highlights ─────────────────────────────────────────────────────── */
	.highlights {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		margin-top: 56px;
	}

	.hl {
		padding: 24px 20px;
		border-left: 1px solid var(--line);
	}

	.hl:first-child { border-left: 0; padding-left: 0; }

	.hl-stat {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: clamp(26px, 3.4vw, 36px);
		line-height: 1;
		letter-spacing: -0.02em;
		color: var(--ink);
		font-variant-numeric: tabular-nums;
	}

	.hl-lbl {
		font-family: var(--font-mono);
		font-size: 10.5px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--ink-3);
		margin-top: 10px;
		line-height: 1.45;
		text-wrap: balance;
	}

	/* ── Tech grid ──────────────────────────────────────────────────────── */
	.tech-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 8px;
	}

	.tech {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--r-md);
		padding: 18px 16px 16px;
		display: flex;
		flex-direction: column;
		gap: 4px;
		position: relative;
		transition: border-color 0.2s ease, transform 0.2s ease;
	}

	.tech:hover {
		border-color: color-mix(in oklab, var(--accent) 40%, var(--line));
		transform: translateY(-1px);
	}

	.tech .rank {
		position: absolute;
		top: 12px;
		right: 14px;
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--ink-3);
		letter-spacing: 0.06em;
	}

	.tech-name {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 17px;
		letter-spacing: -0.005em;
		color: var(--ink);
		margin: 0;
	}

	.tech-yrs {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--ink-2);
		margin-top: 2px;
	}

	.tech-yrs .n {
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 17px;
		color: var(--ink);
		margin-right: 4px;
		letter-spacing: -0.01em;
	}

	.tech-bar {
		height: 2px;
		background: var(--line-2);
		border-radius: 999px;
		margin: 12px 0 10px;
		overflow: hidden;
	}

	.tech-bar i {
		display: block;
		height: 100%;
		background: var(--accent);
		border-radius: inherit;
		transform-origin: left;
		animation: barIn 1.0s cubic-bezier(0.2, 0.7, 0.2, 1) both;
	}

	@keyframes barIn {
		from { transform: scaleX(0); }
		to { transform: scaleX(1); }
	}

	.tech-note {
		font-family: var(--font-mono);
		font-size: 10.5px;
		color: var(--ink-3);
		line-height: 1.5;
		letter-spacing: 0.01em;
	}

	/* ── Responsive ─────────────────────────────────────────────────────── */
	@media (max-width: 1024px) {
		.tech-grid { grid-template-columns: repeat(3, 1fr); }
	}

	@media (max-width: 820px) {
		.highlights {
			grid-template-columns: repeat(2, 1fr);
			border: 0;
			gap: 8px;
			margin-top: 40px;
		}

		.hl {
			padding: 16px;
			border: 1px solid var(--line);
			border-left: 1px solid var(--line);
			border-radius: var(--r-md);
		}

		.hl:first-child {
			border-left: 1px solid var(--line);
			padding-left: 16px;
		}

		.tech-grid { grid-template-columns: repeat(2, 1fr); }

	}

	@media (max-width: 560px) {
		.hero { padding-block: 56px 40px; }
		.hero h1 { font-size: clamp(28px, 8vw, 38px); max-width: none; }
		.hero-sub { font-size: 15.5px; }
		.hero-meta { font-size: 11px; gap: 4px 16px; margin-top: 24px; }
		.hero-pill { font-size: 11px; }

		.hero-cta-row { width: 100%; }
		.hero-cta-row .btn { flex: 1; justify-content: center; }

		.highlights { grid-template-columns: 1fr; margin-top: 32px; }
		.hl-stat { font-size: 28px; }

		.tech-grid { grid-template-columns: 1fr; gap: 6px; }
		.tech { padding: 14px 14px 12px; }
		.tech-name { font-size: 16px; }
		.tech-bar { margin: 10px 0 8px; }

	}
</style>
