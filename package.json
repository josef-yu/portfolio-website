{
  "name": "josefyu-portfolio",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/admin-ui & npm run dev -w packages/site",
    "build": "npm run build -w packages/admin-ui && npm run build -w packages/site",
    "preview": "npm run preview -w packages/site",
    "admin:dev": "npm run dev -w packages/admin-ui",
    "admin:build": "npm run build -w packages/admin-ui",
    "site:dev": "npm run dev -w packages/site",
    "site:build": "npm run build -w packages/site",
    "lint": "eslint packages",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,mjs,css,json}\" \"*.{js,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,mjs,css,json}\" \"*.{js,json}\""
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "turbo": "^2.0.0",
    "typescript-eslint": "^8.59.4"
  }
}
